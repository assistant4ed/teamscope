# ---------- Server (Railway) ----------
# Full Postgres connection string — use Supabase "Transaction mode pooler" URL.
# Format: postgresql://postgres.<ref>:<url-encoded-password>@<pooler-host>:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.xxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

PORT=3000
NODE_ENV=production

# ---------- Frontend (Vite) — optional, leave blank in prod ----------
# Only used in local dev when you want to point the UI at a different API host.
# In production the API and frontend are same-origin, so leave empty.
VITE_API_BASE=

# ---------- Gemini (existing feature) ----------
GEMINI_API_KEY=
